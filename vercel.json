{
    "version": 2,
    "//": "Force cache bust commit - re-indexing multi-runtime pipeline layout",
    "builds": [
        {
            "src": "frontend/api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "frontend/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "frontend/$1"
        }
    ]
}